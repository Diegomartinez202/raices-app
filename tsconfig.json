{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Strict Mode */
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,

    /* Bundler & Node mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowJs": true,

    /* Rutas Relativas */
    "paths": {
      "@/*": ["./src/*"],
      "@hooks/*": ["./src/hooks/*"]
    },
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.ts", 
    "src/**/*.tsx", 
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules", 
    "**/*.vue", 
    "/*.vue",
    "src/components/Chat/ChatInput.vue",
    "src/components/Chat/ChatWindow.vue",
    "src/components/Chat/SourceBadge.vue",
    "src/components/AppInitializer.vue"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}