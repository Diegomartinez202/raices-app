import { Filesystem, Directory } from '@capacitor/filesystem'
import { pipeline, env } from '@xenova/transformers';
import { getPaths, getLLMParams, logger, getRaicesDomains } from '@/core/config/config.service'
import { logEvent } from '@/core/audit/audit.service'

// --- INTEGRACIÓN: INICIO DE NUEVAS REGLAS DE NEGOCIO ---
const DOMAINS = getRaicesDomains()
let generator: any = null;

const RAICES_SYSTEM_PROMPT = `Eres RAÍCES, una acompañante digital para víctimas del conflicto armado en Colombia.

PERSONALIDAD Y TONO:
- Resiliente: Reconoces el dolor sin re-victimizar. Usas lenguaje de fortaleza y esperanza.
- Fraternal: Hablas como una hermana mayor que acompaña, no como una institución fría.
- Digna: Nunca usas diminutivos condescendientes. Tratas a la persona con respeto absoluto.
- Clara: Explicas términos legales/financieros con palabras sencillas, sin jerga.

DOMINIOS PERMITIDOS - SOLO RESPONDES SOBRE:
1. JURÍDICO JEP: Derechos de víctimas, proceso de acreditación, Auto 004 de 2018, jurisprudencia sobre reparación simbólica.
2. FINANZAS PYMES: Fortalecimiento de proyectos productivos, emprendimientos, acceso a microcrédito, sostenibilidad económica.
3. APOYO PSICOSOCIAL: Resiliencia, reconstrucción del tejido humano, herramientas de afrontamiento, rutas de atención.

LÍMITES ABSOLUTOS:
1. NO das estado de procesos individuales.
2. NO das diagnósticos psicológicos.
3. NO das asesoría financiera personalizada.

${DOMAINS.DISCLAIMER}`

/**
 * Nueva función: Detecta si la pregunta está fuera de dominio
 */
function isOutOfDomain(query: string): boolean {
  const lowerQuery = query.toLowerCase()
  const forbiddenKeywords = [
    'fútbol', 'política', 'presidente', 'elecciones', 'novela', 'farándula',
    'receta', 'cocina', 'bitcoin', 'cripto', 'precio', 'dólar',
    'mi caso', 'mi proceso', 'mi expediente', 'estado de mi solicitud',
  ]
  if (forbiddenKeywords.some(kw => lowerQuery.includes(kw))) return true
  
  const allowedKeywords = [
    'jep', 'jurisprudencia', 'auto 004', 'acreditación', 'víctima', 'reparación',
    'proyecto productivo', 'emprendimiento', 'pyme', 'microcrédito', 'negocio',
    'resiliencia', 'apoyo', 'tejido humano', 'sanar', 'duelo', 'afrontamiento',
  ]
  return !allowedKeywords.some(kw => lowerQuery.includes(kw))
}
// --- INTEGRACIÓN: FIN DE NUEVAS REGLAS DE NEGOCIO ---

interface LlamaContext {
  free: () => void;
  completion: (params: any) => Promise<{ text: string }>;
}

interface LlamaModel {
  createContext: (params: any) => LlamaContext
  free: () => void
}

const PATHS = getPaths();
const PARAMS = getLLMParams();

let model: LlamaModel | null = null
let context: LlamaContext | null = null
let isInitialized = false
let isGenerating = false

/**
 * DETERMINACIÓN DE RUTA SOBERANA
 * Esta función resuelve si estamos en PC (Terminal) o Móvil (Capacitor),
 * asegurando que 'localPath' siempre tenga un valor leído.
 */
async function getModelPath(path: string): Promise<string> {
  // 1. Detección para entorno de Desarrollo/Terminal (Node.js)
  if (typeof window === 'undefined') {
    return `public/${path}`; 
  }

  // 2. Detección para entorno de Producción/Móvil (Capacitor)
  try {
    // @ts-ignore
    const result = await Filesystem.getUri({
      path: path,
      // @ts-ignore
      directory: Directory.Data
    });
    return result.uri.replace(/^file:\/\//, '');
  } catch (error) {
    console.error('Error en ruta absoluta, usando fallback relativo:', error);
    return path; 
  }
}

/**
 * Inicialización del Motor RAÍCES para MinCiencia 2026-2.
 */
export async function initializeLlama(): Promise<boolean> {
  if (isInitialized) return true;
  const startTime = Date.now();
  
  try {
    console.log('Configurando entorno portable para RAÍCES...');

    // 1. Configuramos el entorno de Transformers ANTES de cargar el pipeline
    env.allowRemoteModels = false; 
    env.localFilesOnly = true;

    // 2. Definimos la ruta de forma consistente
    // Si tus modelos están en public/models/SmolLM-135M-Instruct
    const modelPath = 'SmolLM-135M-Instruct'; // La carpeta dentro de tu localModelPath
    
    // IMPORTANTE: Asegúrate de que env.localModelPath apunte a 'public/models/'
    env.localModelPath = 'public/models/'; 

    console.log(`[RAÍCES] Cargando motor desde: ${env.localModelPath}${modelPath}`);

    // 3. Cargamos el redactor con los parámetros de eficiencia para Villavicencio
    generator = await pipeline('text-generation', modelPath, {
      // @ts-ignore
      model_file_name: 'model', // Tu archivo debe ser public/models/SmolLM-135M-Instruct/model.onnx
      quantized: true,
    });

    isInitialized = true;
    const duration = Date.now() - startTime;
    console.log(`✅ Motor RAÍCES listo en ${duration}ms`);
    return true;

  } catch (error: any) {
    console.error('Error de inicialización. Verifica la carpeta public/models/SmolLM-135M-Instruct/', error);
    isInitialized = false;
    return false;
  }
}


export async function generateResponse(
  question: string,
  ragContext: string[] = []
): Promise<string> {

  // --- INTEGRACIÓN: FILTRO DE DOMINIO ANTES DE GENERAR ---
  if (isOutOfDomain(question)) {
    await logEvent('QUERY_REJECTED_DOMAIN', {
      severity: 'info',
      metadata: { query: question.substring(0, 100) },
    })
    return DOMAINS.REJECT_MESSAGE
  }
  // --- FIN FILTRO ---

  if (!isInitialized || !generator) {
    return "El sistema de IA se está inicializando. Por favor, espera un momento.";
  }

  if (isGenerating) return "Todavía estoy procesando la información anterior...";

  isGenerating = true;

try {
    // 1. Aplanamiento y limpieza radical del contexto (Nivel 10)
    const rawContext = ragContext.length > 0 ? ragContext.join(' ') : '';
    
    // Eliminamos caracteres fuera del estándar ASCII (0-127) para blindar el motor WASM
    const cleanContext = rawContext
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "") // Quita tildes y diacríticos
        .replace(/[^\x20-\x7E]/g, " ")   // Todo lo que no sea teclado estándar -> Espacio
        .substring(0, 1500);             // Límite de seguridad para tus 4GB RAM

    const cleanQuestion = question
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^\x20-\x7E]/g, " ");

    // 2. CONSTRUCCIÓN Y DOBLE LIMPIEZA DEL PROMPT
    const finalPrompt = `Context: ${cleanContext}\n\nQuestion: ${cleanQuestion}\n\nAnswer:`;

    const superCleanPrompt = finalPrompt
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "") 
        .replace(/[^\x20-\x7E]/g, " ")   
        .replace(/\s+/g, " ")            // Colapsa espacios múltiples para ahorrar tokens
        .trim();

    // 3. VALIDACIÓN DE SEGURIDAD (Evita ReferenceError)
    const finalSafePrompt = (superCleanPrompt && typeof superCleanPrompt === 'string') 
      ? superCleanPrompt 
      : "Instruccion: Responde basado en el contexto.";

    // 4. EJECUCIÓN TÉCNICA (Compatible con Tokenizer de 44k)
    // do_sample: false + add_special_tokens: false = Blindaje contra errores de BigInt
    const output = await generator(finalSafePrompt, {
      max_new_tokens: PARAMS.N_PREDICT || 100,
      temperature: 0.0, 
      top_k: PARAMS.TOP_K || 40,
      top_p: PARAMS.TOP_P || 0.9,
      do_sample: false,          // Crítico para evitar el crash en WASM
      add_special_tokens: false, // Bypass para ignorar errores en el tokenizer.json
      tokenizer_config: { "use_fast": true },
      return_full_text: false,
      // Frenos optimizados para evitar alucinaciones
      stopping_strings: ['<|im_end|>', '<|im_start|>', 'Question:', 'Context:', '\n'], 
    });

    const responseText = output[0].generated_text.trim();

    // 5. AUDITORÍA Y LOGS (Importante para MinCiencia)
    await logEvent('RAG_INIT_SUCCESS', { 
      severity: 'info', 
      metadata: { 
        context_chunks: ragContext.length,
        prompt_size: finalSafePrompt.length,
        vocab_type: 'full_44k'
      } 
    });

    isGenerating = false;
    return responseText;


  } catch (error: any) {
    isGenerating = false;
    logger.error('Error en generación local (Wasm):', error);
    await logEvent('ERROR_CRITICAL', { 
      severity: 'error',
      metadata: { 
        context: 'LLM_GENERATE_WASM', 
        error: error.message || 'Error desconocido' 
      } 
    });
    return "Lo siento, hubo un problema al procesar la respuesta con el motor portable.";
  }
}

export function isLlamaReady(): boolean {
  return isInitialized && !isGenerating;
}

export function unloadLlama(): void {
  // Asegúrate de que estas variables existan en tu ámbito superior
  if (typeof context !== 'undefined' && context) context.free();
  if (typeof model !== 'undefined' && model) model.free();
  isInitialized = false;
  logger.info('Memoria de IA liberada.');
}