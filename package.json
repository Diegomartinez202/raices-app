{
  "name": "raices-app",
  "version": "1.0.0",
  "description": "RAÍCES - IA Edge Soberana para Víctimas del Macrocaso 10. Misión 5: Ciencia para la Paz. Proyecto: Autonomía Informativa como Reparación Simbólica.",
  "author": "Diego Armando Martínez Cano - UAC",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "android": "cap run android",
    "ios": "cap run ios",
    "build:android": "vite build && cap sync android",
    "build:ios": "vite build && cap sync ios",
    "download:assets": "tsx scripts/download-assets.ts",
    "encrypt:corpus": "tsx scripts/encrypt-corpus.ts",
    "corpus:encrypt": "tsx scripts/encrypt-corpus.ts --encrypt",
    "corpus:decrypt": "tsx scripts/encrypt-corpus.ts --decrypt",
    "export:informe": "tsx scripts/export-informe.ts",
    "wipe:test": "tsx scripts/test-panic.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/share": "^6.0.0",
    "@ionic/pwa-elements": "^3.2.2",
    "@xenova/transformers": "^2.17.2",
    "autoprefixer": "^10.4.20",
    "axios": "^1.15.2",
    "capacitor-native-biometric": "^4.2.2",
    "capacitor-secure-storage-plugin": "0.10.0",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.33.0",
    "js-sha256": "^0.11.1",
    "jspdf": "^2.5.1",
    "onnxruntime-web": "^1.19.0",
    "pdf-parse": "^1.1.1",
    "pdf2json": "^4.0.3",
    "pdfjs-dist": "^4.0.379",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "tesseract.js": "^7.0.0",
    "voy-search": "^0.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@types/node": "^22.19.17",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/sqlite3": "^3.1.11",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "postcss": "^8.4.45",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
